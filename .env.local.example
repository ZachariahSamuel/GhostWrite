# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # optional — for admin ops

# ── Groq (server-side fallback) ───────────────────────────────────────────────
# Users provide their own key in the UI. This is a fallback for institution plan.
GROQ_API_KEY=gsk_your_groq_key

# ── OpenRouter (multi-model chat) ─────────────────────────────────────────────
# Free at openrouter.ai — unlocks GPT-4o, Claude, Gemini, Grok in chat
OPENROUTER_API_KEY=sk-or-your_openrouter_key

# ── Detector APIs (optional — statistical predictor used if absent) ───────────
# GPTZero free tier: gptzero.me/plans (100 req/day free)
GPTZERO_API_KEY=your_gptzero_key
# Sapling free tier: sapling.ai/developer (free tier available)
SAPLING_API_KEY=your_sapling_key

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Payments ──────────────────────────────────────────────────────────────────
# DPO Pay (primary — Botswana, Orange Money, MyZaka, Visa/Mastercard)
DPO_COMPANY_TOKEN=your_dpo_company_token
DPO_API_URL=https://secure.3gdirectpay.com/API/v6/

# Paystack (fallback — South Africa, Kenya, Ghana, Nigeria)
PAYSTACK_SECRET_KEY=sk_live_your_paystack_key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_key

# Webhook secret for verifying payment callbacks
PAYMENT_WEBHOOK_SECRET=your_random_secret_string
